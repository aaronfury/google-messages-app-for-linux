{
	"name": "google-messages-app-for-linux",
	"version": "1.0.0",
	"description": "A (lightly) Linux-optimized Electron wrapper for Google Messages",
	"author": "Aaron Fury <aaroneff@pm.me>",
	"license": "MIT",
	"main": "index.js",
	"scripts": {
		"start": "electron .",
		"pack": "electron-builder --dir",
		"dist": "electron-builder --linux",
		"postinstall": "electron-builder install-app-deps",
		"build": "electron-builder build"
	},
	"devDependencies": {
		"electron": "*",
		"electron-builder": "*"
	},
	"dependencies": {
		"electron-store": "*"
	},
	"build": {
		"appId": "com.furiousstudios.google-messages-app-for-linux",
		"productName": "Google Messages for Linux",
		"linux": {
			"target": ["AppImage"],
			"category": "Network;InstantMessaging;Chat;",
			"executableName": "google-messages-app-for-linux",
			"icon": "icon.png",
			"maintainer": "Aaron Fury <aaroneff@pm.me>",
			"synopsis": "A (lightly) Linux-optimized Electron wrapper for Google Messages",
			"artifactName": "google-messages-app-for-linux-${version}-${arch}.${ext}"
		},
		"publish": {
			"provider": "github",
			"owner": "aaronfury",
			"repo": "google-messages-app-for-linux"
		}
	}
}
