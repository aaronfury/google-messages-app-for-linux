{
	"name": "google-messages-desktop-for-linux",
	"version": "1.0.0",
	"description": "Electron wrapper for Google Messages",
	"main": "index.js",
	"scripts": {
		"start": "electron .",
		"pack": "electron-builder --dir",
		"dist": "electron-builder --linux",
		"postinstall": "electron-builder install-app-deps",
		"build": "electron-builder build --save-dev",
		"deploy": "electron-builder build --mac --publish always"
	},
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"electron": "^28.0.0",
		"electron-builder": "^24.6.4"
	},
	"dependencies": {
		"electron-store": "^8.1.0"
	},
	"build": {
		"appId": "com.furiousstudios.google-messages-desktop-for-linux",
		"productName": "Google Messages for Linux",
		"linux": {
			"target": ["AppImage", "deb", "rpm"],
			"category": "Internet",
			"icon": "icon.png",
			"desktop": {
				"Name": "Google Messages for Linux",
				"Comment": "Electron wrapper for Google Messages",
				"Exec": "google-messages-desktop-for-linux",
				"Icon": "google-messages-desktop-for-linux",
				"Terminal": "false",
				"Type": "Application"
			},
			"maintainer": "Aaron Fury <aaroneff@pm.me>"
		}
	}
}
